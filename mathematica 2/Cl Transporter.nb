Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"session", "=", 
  RowBox[{
   RowBox[{"ResourceFunction", "[", "\"\<StartPythonSession\>\"", "]"}], "[", 
   
   RowBox[{"{", "\"\<rdkit\>\"", "}"}], "]"}]}], "\n", 
 RowBox[{"ExternalEvaluate", "[", 
  RowBox[{
  "session", ",", 
   "\"\<from rdkit.Chem import MolFromSmiles, Descriptors\>\""}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{"features", "=", 
  RowBox[{"ExternalFunction", "[", 
   RowBox[{
   "session", ",", 
    "\"\<def features(smiles):\n      m = MolFromSmiles(smiles)\n      vals = \
Descriptors.CalcMolDescriptors(m)\n      return vals\>\""}], 
   "]"}]}]}], "Input",
 CellChangeTimes->{{3.969720140326416*^9, 3.9697201513172607`*^9}},
 CellLabel->"In[59]:=",ExpressionUUID->"0776f19b-3800-4b92-b19a-0644f96d0842"],

